:80 {
	log {
		output stdout
	}
	@landingLangEn {
		path_regexp landingLocaleRoot ^/(?:[a-z]{2})?/?$
		query lng=en
	}
	handle @landingLangEn {
		redir * / 302
	}

	@landingLangRequested {
		path_regexp landingLocaleRoot ^/(?:[a-z]{2})?/?$
		expression {query.lng} != "en" && {query.lng} =~ "^[a-z]{2}$"
	}
	handle @landingLangRequested {
		redir * /{query.lng} 302
	}

	@api {
		path /api*
	}
	handle @api {
		reverse_proxy scrumlr-backend:{$SCRUMLR_SERVER_PORT}
	}

	@landing {
		path / /_astro* /assets*
	}
	handle @landing {
		reverse_proxy scrumlr-landing-page:8080
	}

	@landingLocalePrefix {
		path_regexp landingLocalePrefix ^/[a-z]{2}(?:/.*)?$
	}
	handle @landingLocalePrefix {
		reverse_proxy scrumlr-landing-page:8080
	}

	@frontend {
		path /static* /locales* /login* /board* /new* /timer_finished.mp3 /hotkeys.pdf /legal/* /manifest.json /service-worker.js /emoji-data/*
	}
	handle @frontend {
		reverse_proxy scrumlr-frontend:{$SCRUMLR_LISTEN_PORT}
	}
}

